#ifndef TASK_MANAGER_H
#define TASK_MANAGER_H

#define MAX_TASKS 100

// Task status constants
#define NOT_STARTED 0
#define COMPLETED 1

// Task structure
typedef struct {
    char id[50];
    char description[200];
    int priority;   // 1–5
    int status;     // NOT_STARTED or COMPLETED
} Task;


// Function prototypes

// Displays all tasks (updated list)
void display_tasks(Task tasks[], int task_count);

// Searches and filters tasks (with Skip option)
void search_filter_tasks(Task tasks[], int task_count, int Skip, int priority, int status);

// Marks a task as completed using its ID
void mark_task_complete(Task tasks[], int task_count, const char id[]);

#endif
